# ─── Ledgerium AI — Docker Environment Variables ─────────────────────────────
#
# Copy this to .env in the repo root before running docker compose up.
# Only NEXTAUTH_SECRET is required — everything else has sensible defaults.
#
# Usage:
#   cp .env.docker.example .env
#   # Edit .env and set NEXTAUTH_SECRET
#   docker compose up -d
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret

# Public URL of the application (used for auth callbacks)
NEXTAUTH_URL=https://ledgerium.ai

# Port to expose on the host
PORT=3000

# Stripe (optional — uncomment when billing is wired)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PRO_PRICE_ID=price_xxx
