{
  "manifest_version": 3,
  "name": "Ledgerium AI Recorder",
  "version": "0.1.0",
  "description": "Record browser workflows as evidence-linked process intelligence.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": [],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Open Ledgerium Recorder"
  }
}
