{
  "manifest_version": 3,
  "name": "Ledgerium AI Recorder",
  "version": "2.0.0",
  "description": "Record browser workflows as evidence-linked process intelligence. Zero-refresh capture.",
  "permissions": ["storage", "sidePanel", "tabs", "alarms", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Ledgerium Recorder",
    "default_icon": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/viewer/index.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
