generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  name                 String?
  passwordHash         String   @map("password_hash")
  plan                 String   @default("free") // free, starter, team, growth, enterprise (legacy: pro maps to starter via toPlanType)
  subscriptionStatus   String   @default("none")     @map("subscription_status") // none (default until Stripe webhook sets trialing/active/past_due/canceled)
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  uploadCount          Int      @default(0) @map("upload_count")
  isAdmin              Boolean  @default(false) @map("is_admin")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  uploads             Upload[]
  workflows           Workflow[]
  apiKeys             ApiKey[]
  processDefinitions  ProcessDefinition[]
  processFamilies     ProcessFamily[]
  canonicalComponents CanonicalComponentRecord[]
  groupRelationships  GroupRelationship[]
  insights            ProcessInsight[]
  tags                Tag[]
  portfolios          Portfolio[]
  createdTeams          Team[]          @relation("TeamCreator")
  teamMemberships       TeamMember[]
  sentInvites           TeamInvite[]    @relation("InviteSender")
  acceptedInvites       TeamInvite[]    @relation("InviteAcceptor")
  createdShares         WorkflowShare[] @relation("ShareCreator")
  dashboardPreference   UserDashboardPreference?
  processEvidenceReviews ProcessEvidenceReview[]

  @@map("users")
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  keyHash   String   @unique @map("key_hash") // SHA-256 hash of the key — raw key is never stored
  prefix    String                             // first 8 chars of key for display (e.g. "ldg_a1b2...")
  label     String   @default("Extension")     // user-chosen label
  lastUsedAt DateTime? @map("last_used_at")
  createdAt DateTime @default(now()) @map("created_at")

  /// Workspace FK (iter 082 / TEAM-P02 Part G).
  /// NULL means the key belongs to the user's personal (solo) context.
  /// OnDelete SetNull: deleting a team removes the FK but preserves the key row.
  teamId    String?  @map("team_id")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([teamId])
  @@map("api_keys")
}

model Upload {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  fileName         String   @map("file_name")
  fileSizeBytes    Int?     @map("file_size_bytes")
  uploadedAt       DateTime @default(now()) @map("uploaded_at")
  schemaVersion    String?  @map("schema_version")
  validationStatus String   @default("pending") @map("validation_status") // pending, valid, invalid
  validationErrors String?  @map("validation_errors") // JSON array
  rawJsonPath      String   @map("raw_json_path")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflows Workflow[]

  @@index([userId])
  @@map("uploads")
}

model Workflow {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  sourceUploadId String?  @map("source_upload_id")
  title          String
  description    String?
  toolsUsed      String?  @map("tools_used") // JSON array
  durationMs     Int?     @map("duration_ms")
  stepCount      Int?     @map("step_count")
  phaseCount     Int?     @map("phase_count")
  confidence     Float?
  status         String   @default("active") // active, archived, deleted
  sessionId      String?  @map("session_id")
  shareToken     String?  @unique @map("share_token") // public share link token
  viewCount      Int      @default(0) @map("view_count")
  lastViewedAt   DateTime? @map("last_viewed_at")
  isFavorite     Boolean  @default(false) @map("is_favorite")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  processDefinitionId String? @map("process_definition_id")

  // ─── Path E (iter 076 / PATHE-P01) ──────────────────────────────────────
  // Nullable pointers added additively. Existing rows retain NULL until
  // PATHE-P08 variant clustering + PATHE-P10 graph merge fill them at ingest.
  variantId                   String? @map("variant_id")                       // FK to Variant.id; null at v1.0 migration
  variantFingerprint          String? @map("variant_fingerprint")              // matches Variant.variantHash; computed at ingest
  processGraphVersionAtIngest String? @map("process_graph_version_at_ingest")  // audit trail of graph-detector version at run-ingest time

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload            Upload?            @relation(fields: [sourceUploadId], references: [id])
  artifacts         WorkflowArtifact[]
  processDefinition ProcessDefinition? @relation(fields: [processDefinitionId], references: [id], onDelete: SetNull)
  insights          ProcessInsight[]
  shares            WorkflowShare[]
  tags              WorkflowTag[]
  portfolios        WorkflowPortfolio[]
  processGraphs     ProcessGraph[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([processDefinitionId])
  @@index([variantId])
  @@map("workflows")
}

// ─── Tags & Organization ────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String   @default("#6366f1") // hex color for UI chip
  createdAt DateTime @default(now()) @map("created_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflows WorkflowTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model WorkflowTag {
  id         String   @id @default(uuid())
  workflowId String   @map("workflow_id")
  tagId      String   @map("tag_id")
  createdAt  DateTime @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([workflowId, tagId])
  @@index([workflowId])
  @@index([tagId])
  @@map("workflow_tags")
}

// ─── Portfolio Organization ─────────────────────────────────────────────────

model Portfolio {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  type        String   @default("folder") // folder, project, business_unit, department, custom
  color       String   @default("#6366f1") // hex color for UI
  icon        String?  // optional icon identifier (e.g., "folder", "briefcase", "building")
  parentId    String?  @map("parent_id") // self-referencing for nested portfolios
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Portfolio?         @relation("PortfolioTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Portfolio[]        @relation("PortfolioTree")
  workflows WorkflowPortfolio[]

  @@unique([userId, name, parentId])
  @@index([userId])
  @@index([parentId])
  @@map("portfolios")
}

model WorkflowPortfolio {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  portfolioId String   @map("portfolio_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workflow  Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([workflowId, portfolioId])
  @@index([workflowId])
  @@index([portfolioId])
  @@map("workflow_portfolios")
}

model WorkflowArtifact {
  id           String   @id @default(uuid())
  workflowId   String   @map("workflow_id")
  artifactType String   @map("artifact_type") // process_output, workflow_report, source_bundle, sop, process_map
  schemaVersion String? @map("schema_version")
  contentJson  String?  @map("content_json") // JSON stored as text
  contentPath  String?  @map("content_path") // filesystem path
  createdAt    DateTime @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_artifacts")
}

// ─── Phase 3: Process Intelligence ──────────────────────────────────────────

// ProcessFamily: broad category connecting related exact groups.
// Example: "Email Customer Cities Report" family contains exact groups
// for "World", "US", "EMEA" qualifier variants.
model ProcessFamily {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  familyName            String   @map("family_name")
  familySlug            String   @map("family_slug")
  description           String   @default("")
  confidenceScore       Float    @default(0) @map("confidence_score")
  confidenceBand        String   @default("low") @map("confidence_band") // very_high, high, medium, low, very_low
  totalExactGroups      Int      @default(0) @map("total_exact_groups")
  totalRuns             Int      @default(0) @map("total_runs")
  canonicalIntent       String   @default("") @map("canonical_intent")
  createdFromModelVersion String @default("1.0.0") @map("created_from_model_version")
  explanationJson       String?  @map("explanation_json") // GroupingExplanation JSON
  relatedFamilyIds      String?  @map("related_family_ids") // JSON array of family IDs
  topSystems            String?  @map("top_systems") // JSON array of system names
  commonComponentIds    String?  @map("common_component_ids") // JSON array of component IDs
  metricsJson           String?  @map("metrics_json") // ProcessFamilyMetrics JSON
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  processGroups ProcessDefinition[]

  @@unique([userId, familySlug])
  @@index([userId])
  @@map("process_families")
}

// ProcessDefinition: exact process group — strict cluster of workflow runs
// representing the same real process. Retains existing column names for
// backward compatibility; new fields extend the model.
model ProcessDefinition {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  canonicalName    String   @map("canonical_name")
  description      String?
  pathSignature    String   @map("path_signature")    // colon-separated step category sequence
  runCount         Int      @default(0) @map("run_count")
  variantCount     Int      @default(0) @map("variant_count")
  avgDurationMs    Int?     @map("avg_duration_ms")
  medianDurationMs Int?     @map("median_duration_ms")
  stabilityScore   Float?   @map("stability_score")   // 0-1, sequence stability
  confidenceScore  Float?   @map("confidence_score")  // cluster quality
  intelligenceJson String?  @map("intelligence_json")  // cached PortfolioIntelligence JSON
  analyzedAt       DateTime? @map("analyzed_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // ── New fields for process grouping hierarchy ──
  familyId            String?  @map("family_id")
  normalizedName      String?  @map("normalized_name")
  groupType           String   @default("exact_group") @map("group_type") // exact_group, standalone
  startAnchor         String?  @map("start_anchor") // semantic signature of first step
  endAnchor           String?  @map("end_anchor")   // semantic signature of last step
  confidenceBand      String?  @map("confidence_band") // very_high, high, medium, low, very_low
  explanationJson     String?  @map("explanation_json") // GroupingExplanation JSON
  systems             String?  // JSON array of system names
  intentSignature     String?  @map("intent_signature")
  nameSignature       String?  @map("name_signature") // NormalizedTitle.exactSignature
  stepSignatureHash   String?  @map("step_signature_hash")
  eventSignatureHash  String?  @map("event_signature_hash")
  metricsJson         String?  @map("extended_metrics_json") // ProcessGroupMetrics JSON

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    ProcessFamily?     @relation(fields: [familyId], references: [id], onDelete: SetNull)
  workflows Workflow[]
  insights  ProcessInsight[]
  variants  ProcessVariantRecord[]

  @@index([userId])
  @@index([pathSignature])
  @@index([familyId])
  @@index([nameSignature])
  @@map("process_definitions")
}

// ProcessVariantRecord: a distinct execution path within an exact group.
model ProcessVariantRecord {
  id               String  @id @default(uuid())
  processGroupId   String  @map("process_group_id")
  variantName      String  @map("variant_name")
  variantRank      Int     @default(1) @map("variant_rank")
  runCount         Int     @default(0) @map("run_count")
  percentOfRuns    Float   @default(0) @map("percent_of_runs")
  pathStepCategories String? @map("path_step_categories") // JSON array
  deviationPoints  String? @map("deviation_points") // JSON array of DeviationPoint
  addedSteps       String? @map("added_steps")      // JSON array
  removedSteps     String? @map("removed_steps")    // JSON array
  reorderedSteps   String? @map("reordered_steps")  // JSON array
  avgDurationMs    Int?    @map("avg_duration_ms")
  confidenceScore  Float   @default(0) @map("confidence_score")
  explanationJson  String? @map("explanation_json")  // GroupingExplanation JSON
  isStandard       Boolean @default(false) @map("is_standard")
  isFastest        Boolean @default(false) @map("is_fastest")
  isSlowest        Boolean @default(false) @map("is_slowest")
  isOutlier        Boolean @default(false) @map("is_outlier")
  createdAt        DateTime @default(now()) @map("created_at")

  processGroup ProcessDefinition @relation(fields: [processGroupId], references: [id], onDelete: Cascade)

  @@index([processGroupId])
  @@map("process_variant_records")
}

// CanonicalComponentRecord: a reusable step pattern detected across workflows.
model CanonicalComponentRecord {
  id                    String  @id @default(uuid())
  userId                String  @map("user_id")
  componentName         String  @map("component_name")
  componentType         String  @map("component_type") // action, navigation, data_entry, file_action, verification, decision, integration
  canonicalVerb         String  @map("canonical_verb")
  canonicalObject       String  @map("canonical_object")
  canonicalSystem       String? @map("canonical_system")
  description           String  @default("")
  usageCount            Int     @default(0) @map("usage_count")
  familyCount           Int     @default(0) @map("family_count")
  groupCount            Int     @default(0) @map("group_count")
  avgDurationMs         Int?    @map("avg_duration_ms")
  volatilityScore       Float?  @map("volatility_score")
  automationOpportunityScore Float? @map("automation_opportunity_score")
  commonPredecessors    String? @map("common_predecessors") // JSON array of component keys
  commonSuccessors      String? @map("common_successors")   // JSON array of component keys
  relatedComponentIds   String? @map("related_component_ids") // JSON array of component IDs
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, canonicalVerb, canonicalObject])
  @@index([userId])
  @@index([componentType])
  @@map("canonical_components")
}

// GroupRelationship: edge between any two entities in the hierarchy.
model GroupRelationship {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  sourceType            String   @map("source_type") // family, group, variant, workflow, component
  sourceId              String   @map("source_id")
  targetType            String   @map("target_type")
  targetId              String   @map("target_id")
  relationshipType      String   @map("relationship_type") // same_family, possible_match, shares_component, template_like, parent_child, variant_like
  confidenceScore       Float    @default(0) @map("confidence_score")
  explanationCodes      String?  @map("explanation_codes") // JSON array of ExplanationCode strings
  explanationText       String?  @map("explanation_text")
  createdFromModelVersion String @default("1.0.0") @map("created_from_model_version")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // sourceId and targetId are polymorphic: they reference families, groups,
  // workflows, or components depending on sourceType/targetType.
  // No FK constraint — resolved at the application layer.

  @@index([userId])
  @@index([sourceId])
  @@index([targetId])
  @@index([relationshipType])
  @@map("group_relationships")
}

model ProcessInsight {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  processDefinitionId   String?  @map("process_definition_id")
  workflowId            String?  @map("workflow_id")
  insightType           String   @map("insight_type")    // bottleneck, loop, redundant_step, delay, variance, drift, anomaly
  severity              String   @default("info")         // info, warning, critical
  title                 String
  explanation           String
  recommendation        String?
  evidenceJson          String?  @map("evidence_json")    // JSON: affected runs, values, baselines
  observedValue         String?  @map("observed_value")
  expectedValue         String?  @map("expected_value")
  affectedRunIds        String?  @map("affected_run_ids") // JSON array of workflow IDs
  dismissed             Boolean  @default(false)
  createdAt             DateTime @default(now()) @map("created_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  processDefinition ProcessDefinition? @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  workflow          Workflow?           @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([processDefinitionId])
  @@index([workflowId])
  @@index([insightType])
  @@index([severity])
  @@map("process_insights")
}

// ─── Product Analytics ──────────────────────────────────────────────────────

model AnalyticsEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  eventName   String   @map("event_name")
  properties  String?  // JSON metadata
  url         String?
  source      String   @default("client") // client, server
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─── Phase 4: Teams & Collaboration ─────────────────────────────────────────

model Team {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique  // URL-friendly team identifier
  createdBy   String   @map("created_by")
  plan        String   @default("free") // free, starter, team, growth, enterprise (Team-scoped plan; legacy: pro maps to starter)

  /// Workspace-to-Stripe relationship (iter 081 / TEAM-P01).
  /// Separate from User.stripeCustomerId which is preserved for solo subscribers.
  /// Consumed by TEAM-P03 webhook handler.
  stripeCustomerId     String?  @map("stripe_customer_id")

  /// Workspace-level Stripe subscription ID (iter 081 / TEAM-P01).
  /// Separate from User.stripeSubscriptionId which is preserved for solo subscribers.
  /// Consumed by TEAM-P03 webhook handler and TEAM-P02 effective-plan derivation.
  stripeSubscriptionId String?  @map("stripe_subscription_id")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator     User         @relation("TeamCreator", fields: [createdBy], references: [id])
  members     TeamMember[]
  invites     TeamInvite[]
  apiKeys     ApiKey[]

  @@index([createdBy])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  role      String   @default("member") // owner, admin, member, viewer
  joinedAt  DateTime @default(now()) @map("joined_at")

  /// Soft-deactivate status (iter 081 / TEAM-P01 / D-05 Option A).
  /// Values: 'active' | 'deactivated' | 'pending'.
  /// Consumed by TEAM-P02 effective-plan derivation + TEAM-P03 downgrade cascade.
  /// All existing rows acquire status = 'active' at migration time (NOT NULL DEFAULT).
  status              String    @default("active") @map("status")

  /// Timestamp when soft-deactivate fired (iter 081 / TEAM-P01).
  /// NULL means the member has never been deactivated.
  /// Consumed by TEAM-P03 webhook + TEAM-P07 plan-change banner.
  deactivatedAt       DateTime? @map("deactivated_at")

  /// 30-day grace window deadline (iter 081 / TEAM-P01 / D-05).
  /// Computed as deactivated_at + 30 days at deactivation time.
  /// Consumed by TEAM-P07 plan-change banner.
  reactivationDeadline DateTime? @map("reactivation_deadline")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model TeamInvite {
  id          String    @id @default(uuid())
  teamId      String    @map("team_id")
  email       String
  role        String    @default("member") // member, viewer
  token       String    @unique  // invite acceptance token
  invitedBy   String    @map("invited_by")
  acceptedAt  DateTime? @map("accepted_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  /// Invite revocation timestamp (iter 081 / TEAM-P01).
  /// NULL means the invite has not been revoked.
  /// Consumed by TEAM-P02 invite-accept endpoint + TEAM-P07 acceptance landing.
  revokedAt   DateTime? @map("revoked_at")

  /// The user who accepted this invite (iter 082 / TEAM-P02 Part G).
  /// NULL until the invite is accepted.
  /// OnDelete SetNull: deleting the user nulls the FK but preserves the audit trail.
  acceptedBy  String?   @map("accepted_by")

  team            Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter         User  @relation("InviteSender", fields: [invitedBy], references: [id], onDelete: Cascade)
  acceptedByUser  User? @relation("InviteAcceptor", fields: [acceptedBy], references: [id], onDelete: SetNull)

  @@unique([teamId, email])
  @@index([teamId])
  @@index([email])
  @@index([token])
  @@map("team_invites")
}

model WorkflowShare {
  id          String    @id @default(uuid())
  workflowId  String    @map("workflow_id")
  sharedWith  String    @map("shared_with") // userId or teamId
  shareType   String    @map("share_type")  // user, team
  permission  String    @default("viewer")  // viewer, editor
  sharedBy    String    @map("shared_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sharer   User     @relation("ShareCreator", fields: [sharedBy], references: [id], onDelete: Cascade)

  @@unique([workflowId, sharedWith, shareType])
  @@index([sharedWith])
  @@index([workflowId])
  @@map("workflow_shares")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  tokenHash String    @unique @map("token_hash") // SHA-256 hash — raw token never stored
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// ─── Path D: Dashboard Column-Config Persistence (iter-059 / WDC-P04) ────────

/**
 * One preference document per user.
 *
 * `userId @unique` enforces the 1:1 relationship — there is exactly one
 * preference document per user at all times. `savedViews` live inside the
 * `payload` JSON blob rather than as separate rows; this keeps the model
 * simple for Phase 1 (D+5 can migrate to separate rows if needed).
 *
 * `schemaVersion` mirrors `payload.schemaVersion` for DB-side queries
 * (e.g. "find all rows at version < 2 that need migration").
 *
 * `payload` is a TEXT column on SQLite (Prisma maps String to TEXT).
 * The application layer handles JSON.stringify / JSON.parse via the
 * `serializePreferencesForDb` / `deserializePreferencesFromDb` adapters
 * in `apps/web-app/src/lib/dashboard-columns/persistence.ts`.
 *
 * @see docs/features/dashboard-v3-metrics-engine/PERSISTENCE_SCHEMA.md
 */
model UserDashboardPreference {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemaVersion Int      @default(1) @map("schema_version")
  payload       String   // JSON stored as TEXT (see persistence.ts adapters)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("user_dashboard_preferences")
}

// ─── Path E — Process Graph (iter 076 / PATHE-P01) ──────────────────────────
//
// Append-only versioned graph root per system-architect §A Decision #2.
// `graphVersion` is a monotonic revision counter; `graphSchemaVersion` is the
// semver wire-format pin (`'2.0'` at PATHE-P01 launch).
//
// Immutability: rows are NEVER mutated. New revision = INSERT with higher
// graphVersion. Prior revisions preserved for byte-identical webhook replay
// + audit trail per Path E §M.
//
// JSON payloads are stored as TEXT (SQLite); the application layer handles
// `parseProcessGraphJson` / `serializeProcessGraphToJson` round-trips.

model ProcessGraph {
  id                 String   @id @default(uuid())
  workflowId         String   @map("workflow_id")
  graphVersion       Int      @default(1) @map("graph_version")
  graphSchemaVersion String   @default("2.0") @map("graph_schema_version")
  runCount           Int      @default(0) @map("run_count")
  computedAtMs       BigInt   @map("computed_at_ms")
  isInferred         Boolean  @default(false) @map("is_inferred")
  confidenceScore   Float    @default(0) @map("confidence_score")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  workflow        Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodes           ProcessNode[]
  edges           ProcessEdge[]
  decisionPoints  DecisionPoint[]
  variants        Variant[]

  @@unique([workflowId, graphVersion])
  @@index([workflowId])
  @@map("process_graphs")
}

model ProcessNode {
  id                 String  @id
  processGraphId     String  @map("process_graph_id")
  nodeType           String  @map("node_type")         // closed union — validated at app layer
  rawLabel           String  @map("raw_label")
  normalizedLabel    String? @map("normalized_label")
  applicationLabel   String? @map("application_label")
  routeTemplate      String? @map("route_template")
  confidenceScore    Float   @map("confidence_score")
  isInferred         Boolean @map("is_inferred")
  observationCount   Int     @map("observation_count")
  rawEvidenceJson    String  @default("[]") @map("raw_evidence_json") // JSON: EvidencePointer[]
  createdAt          DateTime @default(now()) @map("created_at")

  processGraph ProcessGraph @relation(fields: [processGraphId], references: [id], onDelete: Cascade)

  @@index([processGraphId])
  @@map("process_nodes")
}

model ProcessEdge {
  id                String  @id
  processGraphId    String  @map("process_graph_id")
  fromNodeId        String  @map("from_node_id")
  toNodeId          String  @map("to_node_id")
  edgeType          String  @map("edge_type")          // closed union — validated at app layer
  runFrequency      Int     @map("run_frequency")
  runFrequencyPct   Float   @map("run_frequency_pct")
  confidenceScore   Float   @map("confidence_score")
  isInferred        Boolean @map("is_inferred")
  rawEvidenceJson   String  @default("[]") @map("raw_evidence_json")
  createdAt         DateTime @default(now()) @map("created_at")

  processGraph ProcessGraph @relation(fields: [processGraphId], references: [id], onDelete: Cascade)

  @@index([processGraphId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("process_edges")
}

model DecisionPoint {
  id              String  @id @default(uuid())
  processGraphId  String  @map("process_graph_id")
  nodeId          String  @map("node_id")
  decisionType    String  @map("decision_type")
  confidenceScore Float   @map("confidence_score")
  isInferred      Boolean @map("is_inferred")
  rawEvidenceJson String  @default("[]") @map("raw_evidence_json")
  createdAt       DateTime @default(now()) @map("created_at")

  processGraph ProcessGraph @relation(fields: [processGraphId], references: [id], onDelete: Cascade)
  conditions   Condition[]

  @@index([processGraphId])
  @@index([nodeId])
  @@map("decision_points")
}

model Condition {
  id              String  @id @default(uuid())
  decisionPointId String  @map("decision_point_id")
  description     String
  conditionType   String  @map("condition_type")
  confidenceScore Float   @map("confidence_score")
  isInferred      Boolean @map("is_inferred")
  rawEvidenceJson String  @default("[]") @map("raw_evidence_json")
  createdAt       DateTime @default(now()) @map("created_at")

  decisionPoint DecisionPoint @relation(fields: [decisionPointId], references: [id], onDelete: Cascade)

  @@index([decisionPointId])
  @@map("conditions")
}

model Variant {
  id                String  @id @default(uuid())
  processGraphId    String  @map("process_graph_id")
  variantHash       String  @map("variant_hash")
  variantLabel      String  @map("variant_label")
  runCount          Int     @map("run_count")
  runFrequencyPct   Float   @map("run_frequency_pct")
  meanDurationMs    Int?    @map("mean_duration_ms")
  stepCount         Int     @map("step_count")
  nodeSequenceJson  String  @default("[]") @map("node_sequence_json")
  rawEvidenceJson   String  @default("[]") @map("raw_evidence_json")
  createdAt         DateTime @default(now()) @map("created_at")

  processGraph ProcessGraph @relation(fields: [processGraphId], references: [id], onDelete: Cascade)

  @@unique([processGraphId, variantHash])
  @@index([processGraphId])
  @@index([variantHash])
  @@map("variants")
}

// ─── Path E — Reviewed-Evidence Retention (CEO directive 2026-05-18 / Appendix C)
//
// One row per explicit user review action. Drives the 365-day retention floor
// for Team / Growth / Enterprise tiers vs 90-day floor for Free / Starter.
//
// Audit-honesty IFF invariant:
//   `EvidencePointer.reviewedAt !== null` IFF a ProcessEvidenceReview row
//   exists with matching (workflow_run_id, step_index).
//
// Cleanup: daily BullMQ `cleanup_expired_evidence_reviews` at 02:00 UTC
// queries `retention_until_ms < <now_ms>` and soft-deletes; hard-deletes on
// day +30.

model ProcessEvidenceReview {
  id                  String   @id @default(uuid())
  evidencePointerId   String   @map("evidence_pointer_id")  // composite "workflowRunId:stepIndex"
  workflowRunId       String   @map("workflow_run_id")
  stepIndex           Int      @map("step_index")
  reviewedBy          String   @map("reviewed_by")
  reviewedAtMs        BigInt   @map("reviewed_at_ms")
  reviewAction        String   @map("review_action")        // mark_reviewed | expand_evidence | act_on_recommendation
  retentionUntilMs    BigInt   @map("retention_until_ms")
  planTierAtReview    String   @map("plan_tier_at_review")
  createdAtMs         BigInt   @map("created_at_ms")

  reviewer User @relation(fields: [reviewedBy], references: [id], onDelete: Cascade)

  @@index([evidencePointerId])
  @@index([retentionUntilMs])
  @@index([workflowRunId, stepIndex])
  @@map("process_evidence_reviews")
}

