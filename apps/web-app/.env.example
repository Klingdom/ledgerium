# ─── Authentication ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── Storage ─────────────────────────────────────────────────────────────────
# All persistent data lives under DATA_DIR.
# In Docker, this should point to a mounted volume (e.g., /app/data).
# In development, defaults to ./data relative to the web-app directory.
DATA_DIR=./data
DATABASE_URL=file:./data/ledgerium.db
# UPLOAD_DIR defaults to DATA_DIR/uploads if not set
# UPLOAD_DIR=./data/uploads

# ─── Stripe (Pro subscription billing) ───────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Create a Product + recurring Price in Stripe Dashboard, then paste the Price ID
STRIPE_PRO_PRICE_ID=price_xxx
# Create a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointing to https://ledgerium.ai/api/billing/webhook
# Events to listen for: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxx
