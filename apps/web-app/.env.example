# ─── Authentication ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── Storage ─────────────────────────────────────────────────────────────────
# All persistent data lives under DATA_DIR.
# In Docker, this should point to a mounted volume (e.g., /app/data).
# In development, defaults to ./data relative to the web-app directory.
DATA_DIR=./data
DATABASE_URL=file:./data/ledgerium.db
# UPLOAD_DIR defaults to DATA_DIR/uploads if not set
# UPLOAD_DIR=./data/uploads

# ─── Stripe (Pro subscription billing) ───────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Create a Product + recurring Price in Stripe Dashboard, then paste the Price ID
STRIPE_PRO_PRICE_ID=price_xxx
# Create a webhook endpoint at https://dashboard.stripe.com/webhooks
# pointing to https://ledgerium.ai/api/billing/webhook
# Events to listen for: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Transactional Email (password reset, team invites) ─────────────────────
# Get an API key from https://resend.com/api-keys

# ── Transactional email — Option A: Hostinger SMTP (preferred) ──────────────
# Set SMTP_PASSWORD to the hello@ledgerium.ai mailbox password to activate
# delivery. Host/port/user default to Hostinger below, so SMTP_PASSWORD is the
# only value required. SMTP takes precedence over RESEND_API_KEY.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@ledgerium.ai
SMTP_PASSWORD=
# Gates whether password-reset / team-invite emails actually send via Resend —
# without this set, sendEmail() falls back to console.log only (dev-safe, but
# means real users never receive the email in a deployed environment).
RESEND_API_KEY=
# Sender identity used on outgoing transactional email. Must be a verified
# domain/sender in Resend or delivery will fail.
EMAIL_FROM="Ledgerium AI <noreply@ledgerium.ai>"
# Public site origin used to build absolute links (e.g. password-reset URLs).
# An incorrect value here produces a broken/unreachable reset link even when
# the email itself delivers successfully.
NEXT_PUBLIC_SITE_URL=https://ledgerium.ai
